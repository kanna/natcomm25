\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \ref  {sub@fig:rms_ABB1} Root Mean Square Error (RMSE) (in $^{\circ }$C) between model forecasts and in-situ AUV temperature observations for 29\textsuperscript  {th}–-30\textsuperscript  {st} October. Scenario \textbf  {A} corresponds to the baseline statistical forecast generated based on {\color  {blue}{\{R1: CMEMS\}}} data up to the 29\textsuperscript  {th}. Scenarios \textbf  {B} and \textbf  {B1} represent forecasts for the 30\textsuperscript  {th} without and with respectively, the assimilation of AUV observations collected by XP2. \ref  {sub@fig:rms_c} RMSE, between the statistical model forecasts and in-situ AUV temperature measurements for 31\textsuperscript  {th} October, for scenarios \textbf  {C} and \textbf  {C1-–C4}. These forecasts were initialized using {\color  {blue}{\{R1: CMEMS\}}} data available up to the 30\textsuperscript  {th}, and the assimilation steps progressively incorporate AUV observations collected on previous days. Results are shown for each vehicle and for the combined dataset (“All AUVs”). \ref  {sub@fig:rms_d} Same as \ref  {sub@fig:rms_c}, but for scenarios \textbf  {D} and \textbf  {D1-–D4}, in which forecasts for the 31\textsuperscript  {th} were initialized using {\color  {blue}{\{R1: CMEMS\}}} data available only up to the 29\textsuperscript  {th}. Assimilation configurations \textbf  {D1-–D4} mirror those of the \textbf  {C}--series but start from this less favorable prior state. Results are again presented per vehicle and for the aggregated dataset.\relax }}{16}{figure.caption.12}}
\newlabel{fig:rms}{{6}{16}{\subref {fig:rms_ABB1} Root Mean Square Error (RMSE) (in $^{\circ }$C) between model forecasts and in-situ AUV temperature observations for 29\textsuperscript {th}–-30\textsuperscript {st} October. Scenario \textbf {A} corresponds to the baseline statistical forecast generated based on \rone {CMEMS} data up to the 29\textsuperscript {th}. Scenarios \textbf {B} and \textbf {B1} represent forecasts for the 30\textsuperscript {th} without and with respectively, the assimilation of AUV observations collected by XP2. \subref {fig:rms_c} RMSE, between the statistical model forecasts and in-situ AUV temperature measurements for 31\textsuperscript {th} October, for scenarios \textbf {C} and \textbf {C1-–C4}. These forecasts were initialized using \rone {CMEMS} data available up to the 30\textsuperscript {th}, and the assimilation steps progressively incorporate AUV observations collected on previous days. Results are shown for each vehicle and for the combined dataset (“All AUVs”). \subref {fig:rms_d} Same as \subref {fig:rms_c}, but for scenarios \textbf {D} and \textbf {D1-–D4}, in which forecasts for the 31\textsuperscript {th} were initialized using \rone {CMEMS} data available only up to the 29\textsuperscript {th}. Assimilation configurations \textbf {D1-–D4} mirror those of the \textbf {C}--series but start from this less favorable prior state. Results are again presented per vehicle and for the aggregated dataset.\relax }{figure.caption.12}{}}
